{
    "name": "traffic-kids",
    "version": "1.0.0",
    "description": "Web app giáo dục an toàn giao thông cho trẻ em - Traffic Kids (Bé Vui Giao Thông)",
    "private": true,
    "workspaces": [
        "frontend",
        "backend",
        "types"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
        "dev:frontend": "cd frontend && npm run dev",
        "dev:backend": "cd backend && npm run dev",
        "build": "npm run build:frontend && npm run build:backend",
        "build:frontend": "cd frontend && npm run build",
        "build:backend": "cd backend && npm run build",
        "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
        "prisma:generate": "cd backend && npm run prisma:generate",
        "prisma:migrate": "cd backend && npm run prisma:migrate",
        "prisma:seed": "cd backend && npm run seed"
    },
    "keywords": [
        "education",
        "traffic-safety",
        "children",
        "game",
        "nextjs",
        "express",
        "prisma"
    ],
    "author": "Traffic Kids Team",
    "license": "MIT",
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}