# ───────────────────────────────────────────────
# Backend Configuration
# ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Frontend URL (dùng cho CORS). Khi deploy, đặt đúng domain production.
FRONTEND_URL=http://localhost:3000

# ───────────────────────────────────────────────
# Database
# ───────────────────────────────────────────────
# Mặc định dùng SQLite cho phát triển cục bộ:
DATABASE_URL="file:./dev.db"
# Khi deploy production, khuyến nghị dùng PostgreSQL/MySQL, ví dụ:
# DATABASE_URL="postgresql://user:password@host:5432/traffic_kids?schema=public"
# (đổi provider trong prisma/schema.prisma thành "postgresql" nếu chuyển DB)

# ───────────────────────────────────────────────
# Auth
# ───────────────────────────────────────────────
# BẮT BUỘC ở production: đặt chuỗi ngẫu nhiên đủ mạnh (vd: openssl rand -base64 48).
# Backend sẽ từ chối khởi động ở production nếu để trống hoặc dùng giá trị mặc định.
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# Số vòng băm bcrypt
BCRYPT_SALT_ROUNDS=10
